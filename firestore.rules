rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Family data is accessible to anyone who knows the family UUID.
    // The UUID (128-bit random) acts as the shared secret for this family.
    // No user accounts needed — device role is managed locally on each device.
    match /families/{familyId}/data/{document} {
      allow read, write: if true;
    }
  }
}
