rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Parent profile: readable/writable only by the owner
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Family data: only the parent (whose uid == familyId) can access
    match /families/{familyId}/data/{document} {
      allow read, write: if request.auth != null && request.auth.uid == familyId;
    }
  }
}
